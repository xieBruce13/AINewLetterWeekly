# ============================================================
# Newsletter build artifacts
# ============================================================
# PDF: generated locally (print from browser); do not commit.
*.pdf
# HTML: ignore by default, but track rendered issues under newsletter_runs/.
*.html
!newsletter_runs/**/*.html

# Legacy config from an earlier rendering pipeline
pdf-config.json
pdf-style.css

# Per-run scratch / image cache (keep the JSON artifacts, skip binaries)
# Uncomment if you prefer not to version run images:
# newsletter_runs/**/images/

# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.Python
pip-log.txt
pip-delete-this-directory.txt

# ============================================================
# Secrets / env
# ============================================================
.env
.env.*
!.env.example
*.pem
*.key
credentials.json

# ============================================================
# OS
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ============================================================
# Editors / IDEs
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# Claude Code per-user local settings (allow-lists, etc.)
.claude/settings.local.json

# ============================================================
# Logs / debug
# ============================================================
*.log
logs/
debug-*.log

# ============================================================
# Fast pipeline scratch
# ============================================================
newsletter_runs/**/raw_scraped.json

# Local commit-message scratch files
.commit_msg.tmp
*.commit_msg.tmp
