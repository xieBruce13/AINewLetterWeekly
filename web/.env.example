# Copy to .env.local and fill in.

# Postgres with pgvector. Local: postgres://postgres:postgres@localhost:5432/newsletter
# Supabase / Neon: paste their pooled connection string.
DATABASE_URL=

# Auth.js — generate with `openssl rand -base64 32`
AUTH_SECRET=

# Email magic link via Resend (https://resend.com)
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM="AI Newsletter <noreply@example.com>"

# (Optional) Google OAuth — leave blank to disable.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# LLM key. As of 2026-05-05 the project uses OpenAI for *everything*:
#   - chat agent + memory extraction + smart rerank → gpt-5-mini
#   - embeddings (search / personalization / memory retrieval)
#     → text-embedding-3-small
# One key, one provider. Without it the site degrades gracefully (cheap
# rerank-only feed, chat 503), so you can still run a read-only demo.
OPENAI_API_KEY=

# App URL (used by NextAuth for callback URLs)
NEXTAUTH_URL=http://localhost:3000
